{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "server.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "server.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "server.js"
    },
    {
      "source": "/admin/(.*)",
      "destination": "server.js"
    },
    {
      "source": "/api-docs/(.*)",
      "destination": "server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}

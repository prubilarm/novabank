{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "api/index.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/admin/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/static/(.*)",
      "destination": "/frontend/static/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/frontend/favicon.ico"
    },
    {
      "source": "/manifest.json",
      "destination": "/frontend/manifest.json"
    },
    {
      "source": "/logo192.png",
      "destination": "/frontend/logo192.png"
    },
    {
      "source": "/((?!api|auth|admin|health|static|favicon.ico|manifest.json|logo192.png).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
